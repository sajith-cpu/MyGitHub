    {
      "name": "Add Place API",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "/**\r",
              " * Verify the Status Code\r",
              " * Verify the Response Time\r",
              " * Verify the Response Body Status\r",
              " * \r",
              " */\r",
              "\r",
              "pm.test(\"Verify the Status Code\", function(){\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Response time is less than 2 Sec\", function () {\r",
              "    pm.expect(pm.response.responseTime).to.be.below(2000);\r",
              "});\r",
              "\r",
              "pm.test(\"Verify the Response Body Status\", function () {\r",
              "    var jsonData = pm.response.json();\r",
              "    pm.expect(jsonData.status).to.eql(\"OK\");\r",
              "});\r",
              "\r",
              "pm.test(\"Verify the Response Body Scope\", function () {\r",
              "    var jsonData = pm.response.json();\r",
              "    pm.expect(jsonData.scope).to.eql(\"APP\");\r",
              "});\r",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
