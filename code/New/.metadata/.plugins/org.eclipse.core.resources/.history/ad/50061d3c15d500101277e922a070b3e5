package javaprogramadvanced;

public class Array2ndLargeElement {

	public static void main(String[] args) {
		int arr[] = { 4, 5, 7, 11, 9, 13, 8, 12 };
		int n = arr.length;
		int temp=0;
		for (int i = 0; i < n; i++) {
			for (int j = i + 1; j < n; j++) {
				if (arr[i] > arr[j]) {
					temp=arr[j];
				}

			}

		}
		System.out.print(temp);
	}
}
