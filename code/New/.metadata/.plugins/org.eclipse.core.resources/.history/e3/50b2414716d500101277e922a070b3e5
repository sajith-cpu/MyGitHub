package javaprogramadvanced;

public class Array2ndLargeElement {

	public static void main(String[] args) {
		int arr[] = { 4, 5, 7, 11, 9, 10, 8, 12 };
		int n = arr.length;
		int temp=0;
		
		for (int i = 1; i < n; i++) {
			for (int j = i + 1; j < n; j++) {
				if (arr[i] > arr[j]) {
					temp=arr[i];   
					arr[i]=arr[j];
					arr[j]=temp;
				}

			}

		}
		System.out.print(arr[(arr.length)-1]);
	}
}
